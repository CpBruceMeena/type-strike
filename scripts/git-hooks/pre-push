#!/bin/sh

# Pre-push hook: protect main/master from direct pushes
# As the sole developer, we allow pushes only from non-main branches.
# To push to main, merge via a feature branch or use --no-verify.

BRANCH=$(git rev-parse --abbrev-ref HEAD)

if [ "$BRANCH" = "main" ] || [ "$BRANCH" = "master" ]; then
  echo ""
  echo "  ❌ Direct pushes to $BRANCH are not allowed."
  echo "  ─────────────────────────────────────────────"
  echo "  As the sole developer, use this workflow:"
  echo ""
  echo "    1. Create a feature branch: git checkout -b feat/your-change"
  echo "    2. Commit your changes there"
  echo "    3. Push the feature branch:   git push origin feat/your-change"
  echo "    4. Merge locally:             git checkout main && git merge feat/your-change"
  echo "    5. Then push main:            git push origin main --no-verify"
  echo ""
  echo "  Or skip this check with:       git push origin main --no-verify"
  echo ""
  exit 1
fi

# Run lint check before push
if [ -f "type-strike-android/gradlew" ]; then
  echo "  📱 Running Android lint before push..."
  cd type-strike-android && ./gradlew lintDebug 2>/dev/null
  cd ..
fi

exit 0
